{
    "name": "garagemweb",
    "version": "1.0.0",
    "description": "Sistema completo de gestÃ£o + NextCar Leads",
    "type": "commonjs",
    "main": "server.js",
    "scripts": {
        "dev": "nodemon server.js",
        "lint": "eslint --ext .js, -f ./node_modules/eslint-friendly-formatter . --fix",
        "prepush": "npm run lint",
        "start": "node server.js",
        "leads:setup": "node scripts/leads/setup-database.js",
        "leads:test-email": "node scripts/leads/test-email.js",
        "leads:test-db": "node scripts/leads/test-database.js",
        "leads:backfill": "RUN_BACKFILL=true node server.js",
        "leads:seed-test": "node scripts/leads/seed-test-leads.js",
        "health": "curl -s http://localhost:3001/health | jq . || echo 'Servidor nÃ£o estÃ¡ rodando'",
        "leads:status": "curl -s http://localhost:3001/garagemweb/api/leads/email/status || echo 'Servidor nÃ£o estÃ¡ rodando'",
        "leads:stats": "curl -s http://localhost:3001/garagemweb/api/leads/dashboard/stats || echo 'Servidor nÃ£o estÃ¡ rodando'",
        "docker:build": "docker build -t inventarionline .",
        "docker:run": "docker run -p 3001:3001 --env-file .env inventarionline",
        "db:migrate:nextcar": "node scripts/migrate-nextcar.js",
        "db:migrate:nextcar:reset": "node scripts/migrate-nextcar.js --reset-target"
    },
    "author": "RenatoFilho",
    "license": "MIT",

        "cors": "^2.8.5",
        "dotenv": "^16.0.0",
        "dotenv-safe": "^8.2.0",
        "express": "^4.22.1",
        "express-promise-router": "^4.1.1",
        "fast-xml-parser": "^5.3.7",
        "github": "^14.0.0",
        "imap": "^0.8.19",
